# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# `.env.local` is loaded first; `.env` fills in any keys not set there.

# Target dApp URL. The assessment targets `/asset`.
DAPP_URL=https://dev.tradegenius.com/asset

# Test-only seed phrase. 12 or 24 words, space-separated. NEVER a wallet
# that holds real funds. Never commit a real value.
WALLET_SEED=test test test test test test test test test test test junk

# Password MetaMask onboarding sets when Dappwright bootstraps.
WALLET_PASSWORD=TestTest123

# Pin the MetaMask extension version Dappwright downloads. Leave blank to
# use `MetaMaskWallet.recommendedVersion` from the installed Dappwright
# build.
METAMASK_VERSION=

# Launch Chromium headless. Chromium extensions historically required
# headed mode; Playwright supports `--headless=new` with extensions now,
# but verify on the first green run before flipping to true.
HEADLESS=false

# Logger namespace filter (uses the `debug` package). Examples:
#   DEBUG=tradegenius:*            — all tradegenius-namespaced logs
#   DEBUG=tradegenius:hooks:*      — only the hooks module
# Leave blank for silent output.
DEBUG=
